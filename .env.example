# Vibedentify configuration.
# All variables are OPTIONAL — the defaults shown are what the app uses if unset.
# Copy to `.env` and adjust, or simply `export` the ones you want to change.

# Directory holding the Essentia model files (*.pb) and an optional custom_head.npz.
MODEL_DIR=~/essentia_models

# SQLite database file: analysis cache + tags + vibes.
GENRE_DB=~/genre_v2.db

# Optional trained custom genre head (produced by a train_head.py step).
CUSTOM_HEAD=~/essentia_models/custom_head.npz

# Optional override for the MAEST model file used by /compare.
# MAEST_MODEL=~/essentia_models/discogs-maest-30s-pw-1.pb

# Host to bind the dev server to. 127.0.0.1 = localhost only.
# SECURITY: /batch and /save_training read/copy server-side paths, so this app
# must NOT be exposed on a public interface. Keep it on 127.0.0.1.
GENRE_HOST=127.0.0.1

# Max upload size in MB (guards against a giant file exhausting memory).
MAX_UPLOAD_MB=512

# Set to 1 to serve instant fake results with no models loaded (UI/dev testing).
FAKE_ANALYZER=0

# --- External metadata lookup (the 🔎 per-row button) -------------------------
# All optional: a source with no key is simply skipped (MusicBrainz needs none).
# Discogs — https://www.discogs.com/settings/developers. EITHER a personal access
# token, OR a consumer key + secret (both authenticate /database/search; the token
# wins if set). A bare consumer key alone is not enough — the secret is required.
DISCOGS_TOKEN=
DISCOGS_KEY=
DISCOGS_SECRET=
# Last.fm API key — https://www.last.fm/api/account/create
LASTFM_KEY=
